FROM python:3.12-slim

ENV PIP_DEFAULT_TIMEOUT=120 \
    PIP_RETRIES=5

WORKDIR /app

COPY pyproject.toml README.md AGENTS.md GIT-FLOW.md test.sh Dockerfile.test ./
COPY .github ./.github
COPY coordination ./coordination
COPY catalogue ./catalogue
COPY products ./products
COPY docs ./docs
COPY scripts ./scripts
COPY src ./src
COPY tests ./tests

RUN python -m pip install .

CMD ["python", "scripts/run_all_tests.py"]
