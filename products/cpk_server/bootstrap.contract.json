{
  "schema": "cpk-server.bootstrap-contract",
  "environment": [
    {
      "name": "CPK_SERVER_MODE",
      "required": true,
      "allowed_values": ["execution-capable"]
    },
    {
      "name": "CPK_CONTROL_AUTH_CONFIGURED",
      "required": true,
      "allowed_values": ["true"]
    },
    {
      "name": "CPK_PORT",
      "required": true,
      "allowed_values": ["1..65535"]
    },
    {
      "name": "CPK_WORKPLACE_DATABASE_URL",
      "required": true,
      "allowed_values": ["runtime-provided-postgres-url"]
    },
    {
      "name": "CPK_ACTIVITY_HISTORY_DATABASE_URL",
      "required": true,
      "allowed_values": ["runtime-provided-postgres-url"]
    },
    {
      "name": "CPK_OBSERVER_STATE_DATABASE_URL",
      "required": true,
      "allowed_values": ["runtime-provided-postgres-url"]
    },
    {
      "name": "CPK_GRAPH_TOPOLOGY_DATABASE_URL",
      "required": true,
      "allowed_values": ["runtime-provided-postgres-url"]
    }
  ],
  "runtime_inputs": [
    "authorization header is runtime-supplied",
    "store endpoints are runtime-supplied and never echoed by readiness"
  ]
}
