{
  "schema": "cpk-server.bootstrap-contract",
  "environment": [
    {
      "name": "CPK_SERVER_MODE",
      "required": true,
      "allowed_values": [
        "execution-capable"
      ]
    },
    {
      "name": "CPK_CONTROL_AUTH_CONFIGURED",
      "required": true,
      "allowed_values": [
        "true"
      ]
    },
    {
      "name": "CPK_PORT",
      "required": true,
      "allowed_values": [
        "1..65535"
      ]
    },
    {
      "name": "CPK_RUNTIME_INTERPRETERS",
      "required": true,
      "allowed_values": [
        "none",
        "docker"
      ]
    },
    {
      "name": "CPK_IMAGE_PULL_CREDENTIAL_RESOLVER",
      "required": false,
      "allowed_values": [
        "none",
        "docker-config"
      ]
    },
    {
      "name": "CPK_PRODUCT_SECRET_RESOLVER",
      "required": false,
      "allowed_values": [
        "none",
        "local-development"
      ]
    },
    {
      "name": "CPK_PRODUCT_SECRET_VALUES_JSON",
      "required": false,
      "allowed_values": [
        "runtime-secret-reference-to-value-map"
      ]
    },
    {
      "name": "DOCKER_CONFIG",
      "required": false,
      "allowed_values": [
        "container-local-docker-config-directory"
      ]
    },
    {
      "name": "CPK_WORKPLACE_DATABASE_URL",
      "required": true,
      "allowed_values": [
        "runtime-provided-postgres-url"
      ]
    },
    {
      "name": "CPK_ACTIVITY_HISTORY_DATABASE_URL",
      "required": true,
      "allowed_values": [
        "runtime-provided-postgres-url"
      ]
    },
    {
      "name": "CPK_OBSERVER_STATE_DATABASE_URL",
      "required": true,
      "allowed_values": [
        "runtime-provided-postgres-url"
      ]
    },
    {
      "name": "CPK_GRAPH_TOPOLOGY_DATABASE_URL",
      "required": true,
      "allowed_values": [
        "runtime-provided-postgres-url"
      ]
    }
  ],
  "runtime_inputs": [
    "authorization header is runtime-supplied",
    "runtime interpreter authority is selected explicitly and never inferred",
    "store endpoints are runtime-supplied and never echoed by readiness",
    "image pull credential authority is selected explicitly and resolved only at runtime interpreter dispatch",
    "product secret authority is selected explicitly and resolved only at runtime interpreter dispatch"
  ]
}
